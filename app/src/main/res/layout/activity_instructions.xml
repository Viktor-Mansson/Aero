<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink"
    tools:context=".InstructionsActivity">

    <ImageView
        android:id="@+id/victoryView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="40dp"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/whiteboard" />

    <Button
        android:id="@+id/homeButtonInstructions"
        android:layout_width="89dp"
        android:layout_height="70dp"
        android:text="Go back"
        android:textSize="15sp"
        app:backgroundTint="@color/eggwhite"
        app:layout_constraintBottom_toBottomOf="@+id/victoryView"
        app:layout_constraintEnd_toEndOf="@+id/victoryView"
        app:layout_constraintHorizontal_bias="0.1"
        app:layout_constraintStart_toStartOf="@+id/victoryView"
        app:layout_constraintTop_toTopOf="@+id/victoryView"
        app:layout_constraintVertical_bias="0.042"
        app:shapeAppearanceOverlay="@style/Circular"
        app:strokeColor="#000000"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="292dp"
        android:layout_height="75dp"
        android:gravity="center"
        android:text="Instructions"
        android:textSize="40sp"
        app:layout_constraintBottom_toBottomOf="@+id/victoryView"
        app:layout_constraintEnd_toEndOf="@+id/victoryView"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="@+id/victoryView"
        app:layout_constraintTop_toTopOf="@+id/victoryView"
        app:layout_constraintVertical_bias="0.18" />

    <TextView
        android:id="@+id/instructionText"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="1. start by doing a throwing motion\n\n2. hold phone normally 🙂\n\n3. tilt the phone to move plane and avoid obstacles\n\n4. Don't crash the plane"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/victoryView"
        app:layout_constraintEnd_toEndOf="@+id/victoryView"
        app:layout_constraintStart_toStartOf="@+id/victoryView"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        app:layout_constraintVertical_bias="0.100000024" />


    <ImageView
        android:id="@+id/instructions"
        android:layout_width="275dp"
        android:layout_height="175dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@+id/victoryView"
        app:layout_constraintEnd_toEndOf="@+id/victoryView"
        app:layout_constraintStart_toStartOf="@+id/victoryView"
        app:layout_constraintTop_toBottomOf="@+id/instructionText"
        app:layout_constraintVertical_bias="0.469"
        app:srcCompat="@drawable/instructions" />

</androidx.constraintlayout.widget.ConstraintLayout>